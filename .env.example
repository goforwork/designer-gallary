# 复制本文件为 .env 后填写真实配置
# .env 包含敏感信息，请勿提交到 Git

# ===========================
# 服务器部署配置（首次部署前需要向用户询问）
# ===========================

# 服务器公网 IP
SERVER_HOST=your-server-ip

# 服务器登录用户名（例如：ubuntu、root）
SERVER_USER=ubuntu

# 服务器登录密码
SERVER_PASSWORD=your-server-password

# 其他配置（通常不需要修改）：
#   应用目录：/opt/designer-gallery/app
#   数据目录：/opt/designer-gallery/data
#   日志目录：/opt/designer-gallery/logs
#   SSH 端口：22
